{
  "name": "lifeos",
  "version": "0.1.0",
  "private": true,
  "description": "lifeOS — a personal life operating system. Reports, calendar, vision & plan tracker for Zack.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "dev": "pnpm --filter @lifeos/web dev",
    "build": "pnpm --filter @lifeos/web build",
    "preview": "pnpm --filter @lifeos/web preview",
    "lint": "pnpm -r --parallel run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "typecheck": "pnpm -r --parallel run typecheck",
    "content:build": "pnpm --filter @lifeos/web content:build",
    "migrate:from-org-roam": "node scripts/migrate-from-org-roam.mjs"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
